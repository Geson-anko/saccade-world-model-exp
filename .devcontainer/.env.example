# .devcontainer/.env は initialize.sh が host の uid/gid を書き込む (gitignore 済み)。
# これはサンプル兼ドキュメント。HOST_UID/HOST_GID は自動生成されるため通常は
# 手で用意する必要はないが、DATA_DIR だけは環境ごとに手動で設定する必要がある。
HOST_UID=1000
HOST_GID=1000
# DATA_DIR: host 上のデータセットの場所 (環境ごとに異なる・必須)。
# compose が container の /data に read-only マウントする。未設定だと
# initialize.sh / compose がエラーで停止する。
DATA_DIR=/path/to/datasets
